{
  "_comment": "UltraCostEffective 极致节能 — Claude Code settings.json 模板",
  "_description": "复制此文件内容到项目根目录的 settings.json（与 CLAUDE.md 同级）。ultra-cost-effective/ 目录需在项目根目录下。",
  "_version": "1.0.0",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ultra-cost-effective/helpers/tokenforge-hook.cjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ultra-cost-effective/helpers/perf/perf-tracker.cjs --capture",
            "timeout": 3000
          }
        ]
      }
    ]
  },

  "mcpServers": {
    "lean-ctx": {
      "command": "lean-ctx",
      "args": ["mcp"]
    }
  },

  "permissions": {
    "allow": [
      "Bash(npm install -g lean-ctx-bin:*)",
      "Bash(lean-ctx:*)",
      "Bash(node ultra-cost-effective/helpers/tokenforge.cjs:*)",
      "Bash(node ultra-cost-effective/helpers/tokenforge-hook.cjs:*)",
      "Bash(node ultra-cost-effective/helpers/skill-loader.cjs:*)",
      "Bash(node ultra-cost-effective/helpers/prefix-validator.cjs:*)",
      "Bash(node ultra-cost-effective/helpers/cache-monitor.cjs:*)",
      "Bash(node ultra-cost-effective/helpers/perf/perf-tracker.cjs:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(cargo:*)",
      "Bash(pytest:*)",
      "Bash(go test:*)"
    ]
  },

  "environment": {
    "ULTRA_COST_EFFECTIVE_PLATFORM": "claude",
    "ULTRA_COST_EFFECTIVE_LEVEL": "medium"
  }
}
